<p>
  You've been added to the call list for <strong><%= @summary %></strong>.
</p>

<p style="margin-top: 16px;">
  <strong><%= @start_time.strftime('%A, %B %-d, %Y') %></strong><br>
  <%= @start_time.strftime('%-I:%M %p') %> – <%= @end_time.strftime('%-I:%M %p') %>
  <% if @location.present? %>
    · <%= @location %>
  <% end %>
</p>

<% if @description.present? %>
  <p style="margin-top: 16px; color: #6b7280;"><%= @description %></p>
<% end %>

<p style="margin-top: 16px; color: #6b7280;">A calendar invite is attached to this email.</p>
